GCP_PROJECT=project-3a2a0060-1f47-4423-8ff
BQ_DATASET=movie_trailers
BQ_LOCATION=us-central1

# Required by Settings even when the discover/stats/comments phases are skipped.
# Any non-empty string works — they are never used in the transcripts-only path.
TMDB_API_KEY=unused
YOUTUBE_API_KEY=unused

# How many trailers to attempt per invocation.
TRANSCRIPTS_MAX_PER_RUN=500

# peach_server has plenty of RAM, use medium for better accuracy.
WHISPER_MODEL_NAME=medium
