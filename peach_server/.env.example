GCP_PROJECT=project-3a2a0060-1f47-4423-8ff
BQ_DATASET=movie_trailers
BQ_LOCATION=us-central1

# Required by Settings even when the discover/stats/comments phases are skipped.
# Any non-empty string works — they are never used in the transcripts-only path.
TMDB_API_KEY=unused
YOUTUBE_API_KEY=unused

# How many trailers to attempt per invocation.
TRANSCRIPTS_MAX_PER_RUN=500

# --- MCP server (the `mcp` service) ---
# Host port for the read-only MCP server. Published to 127.0.0.1 only, so it's
# reachable from this machine at http://localhost:${MCP_PORT}/mcp and nowhere else.
MCP_PORT=8000

# peach_server has plenty of RAM, use medium for better accuracy.
WHISPER_MODEL_NAME=medium

# --- Weekly digest (the `digest` service) ---
# SMTP_* + DIGEST_EMAIL_TO are required to send (see root README for the full set).
# ANTHROPIC_API_KEY enables `send-digest --polish` (Claude rewrites the draft
# posts). Optional — without it, polish silently falls back to template drafts.
# ANTHROPIC_API_KEY=sk-ant-...
# CONTENT_POLISH_MODEL=claude-opus-4-8   # default; override only if needed
